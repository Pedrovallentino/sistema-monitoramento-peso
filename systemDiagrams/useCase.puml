@startuml
title Diagrama de Casos de Uso - Frontend de Monitoramento de Gás

left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial

actor "Usuário" as User

rectangle "Frontend de Monitoramento de Gás" {
  usecase "Visualizar peso atual" as UC1
  usecase "Visualizar porcentagem\nde gás restante" as UC2
  usecase "Visualizar status\ndo botijão" as UC3
  usecase "Visualizar quantidade\nde trocas realizadas" as UC4
  usecase "Visualizar gráfico\nde consumo" as UC5
  usecase "Visualizar última atualização" as UC6
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6

@enduml